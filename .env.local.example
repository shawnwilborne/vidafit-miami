# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic (Claude API — for AI nudges via Edge Functions)
ANTHROPIC_API_KEY=sk-ant-...

# Nutritionix (food search)
NUTRITIONIX_APP_ID=your-app-id
NUTRITIONIX_APP_KEY=your-app-key

# USDA FoodData Central (fallback)
USDA_API_KEY=your-usda-key

# Google (Places API for Miami restaurants + Calendar)
GOOGLE_PLACES_API_KEY=your-places-key
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-maps-key

# OpenWeatherMap (Miami heat advisory)
OPENWEATHER_API_KEY=your-ow-key
